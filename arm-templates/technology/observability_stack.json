{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_arsenal": {
      "category": "technology",
      "topic": "observability_stack",
      "description": "Sample Linux web app instrumented with Application Insights, Log Analytics workspace, Action Group, and conditional AIOps alert processing rule."
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "environmentName": {
      "type": "string",
      "defaultValue": "production",
      "allowedValues": ["development", "staging", "production"]
    },
    "retention_days": {
      "type": "int",
      "defaultValue": 90,
      "minValue": 30,
      "maxValue": 730,
      "metadata": {"description": "Log Analytics retention in days."}
    },
    "enable_aiops": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {"description": "When true, also provisions an Alert Processing Rule that suppresses Sev3/Sev4 noise during maintenance windows."}
    }
  },
  "variables": {
    "uniqueSuffix": "[take(uniqueString(resourceGroup().id, deployment().name), 8)]",
    "logAnalyticsName": "[concat('arsenal-law-', variables('uniqueSuffix'))]",
    "appInsightsName": "[concat('arsenal-appi-', variables('uniqueSuffix'))]",
    "actionGroupName": "[concat('arsenal-ag-', variables('uniqueSuffix'))]",
    "alertRuleName": "[concat('arsenal-aiops-', variables('uniqueSuffix'))]",
    "appServicePlanName": "[concat('arsenal-asp-obs-', variables('uniqueSuffix'))]",
    "webAppName": "[concat('arsenal-obs-', variables('uniqueSuffix'))]",
    "commonTags": {
      "arsenal": "true",
      "category": "technology",
      "topic": "observability_stack",
      "topicName": "Observability Stack",
      "environment": "[parameters('environmentName')]",
      "managed-by": "arsenal-deployer"
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('commonTags')]",
      "properties": {
        "sku": {"name": "PerGB2018"},
        "retentionInDays": "[parameters('retention_days')]",
        "features": {"enableLogAccessUsingOnlyResourcePermissions": true},
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "tags": "[variables('commonTags')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ],
      "properties": {
        "Application_Type": "web",
        "Flow_Type": "Bluefield",
        "Request_Source": "rest",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]",
        "IngestionMode": "LogAnalytics",
        "publicNetworkAccessForIngestion": "Enabled",
        "publicNetworkAccessForQuery": "Enabled"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-09-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('commonTags')]",
      "kind": "linux",
      "sku": {"name": "F1", "tier": "Free"},
      "properties": {"reserved": true}
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2022-09-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('commonTags')]",
      "kind": "app,linux",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "PYTHON|3.11",
          "alwaysOn": false,
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appSettings": [
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').InstrumentationKey]"
            },
            {
              "name": "ApplicationInsightsAgent_EXTENSION_VERSION",
              "value": "~3"
            },
            {
              "name": "XDT_MicrosoftApplicationInsights_Mode",
              "value": "recommended"
            },
            {
              "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE",
              "value": "false"
            },
            {
              "name": "ARSENAL_TOPIC",
              "value": "observability_stack"
            },
            {
              "name": "ARSENAL_DEMO",
              "value": "true"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Insights/actionGroups",
      "apiVersion": "2023-01-01",
      "name": "[variables('actionGroupName')]",
      "location": "global",
      "tags": "[variables('commonTags')]",
      "properties": {
        "groupShortName": "ArsenalOps",
        "enabled": true,
        "emailReceivers": [],
        "smsReceivers": [],
        "webhookReceivers": []
      }
    },
    {
      "condition": "[parameters('enable_aiops')]",
      "type": "Microsoft.AlertsManagement/actionRules",
      "apiVersion": "2021-08-08",
      "name": "[variables('alertRuleName')]",
      "location": "global",
      "tags": "[variables('commonTags')]",
      "properties": {
        "scopes": ["[resourceGroup().id]"],
        "enabled": true,
        "description": "Suppress Sev3/Sev4 alerts as a sample alert processing rule.",
        "actions": [{"actionType": "RemoveAllActionGroups"}],
        "conditions": [
          {
            "field": "Severity",
            "operator": "Equals",
            "values": ["Sev3", "Sev4"]
          }
        ]
      }
    }
  ],
  "outputs": {
    "webAppUrl": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.Web/sites', variables('webAppName'))).defaultHostName)]"
    },
    "webAppName": {
      "type": "string",
      "value": "[variables('webAppName')]"
    },
    "logAnalyticsWorkspaceName": {
      "type": "string",
      "value": "[variables('logAnalyticsName')]"
    },
    "appInsightsName": {
      "type": "string",
      "value": "[variables('appInsightsName')]"
    },
    "appInsightsConnectionString": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
    },
    "actionGroupId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/actionGroups', variables('actionGroupName'))]"
    },
    "retentionDays": {
      "type": "int",
      "value": "[parameters('retention_days')]"
    },
    "aiopsEnabled": {
      "type": "bool",
      "value": "[parameters('enable_aiops')]"
    }
  }
}
