{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_arsenal": {
      "category": "technology",
      "topic": "observability_stack",
      "description": "Sample Linux container instance instrumented with Application Insights, Log Analytics workspace, Action Group, and conditional AIOps alert processing rule. Uses Azure Container Instances to bypass App Service quota restrictions."
    }
  },
  "parameters": {
    "location": { "type": "string", "defaultValue": "[resourceGroup().location]" },
    "environmentName": { "type": "string", "defaultValue": "production", "allowedValues": ["development", "staging", "production"] },
    "retention_days": { "type": "int", "defaultValue": 90, "minValue": 30, "maxValue": 730 },
    "enable_aiops": { "type": "bool", "defaultValue": true }
  },
  "variables": {
    "uniqueSuffix": "[take(uniqueString(resourceGroup().id, deployment().name), 8)]",
    "logAnalyticsName": "[concat('arsenal-law-', variables('uniqueSuffix'))]",
    "appInsightsName": "[concat('arsenal-appi-', variables('uniqueSuffix'))]",
    "actionGroupName": "[concat('arsenal-ag-', variables('uniqueSuffix'))]",
    "alertRuleName": "[concat('arsenal-aiops-', variables('uniqueSuffix'))]",
    "containerGroupName": "[concat('arsenal-obs-cg-', variables('uniqueSuffix'))]",
    "dnsLabel": "[concat('arsenal-obs-', variables('uniqueSuffix'))]",
    "commonTags": {
      "arsenal": "true",
      "category": "technology",
      "topic": "observability_stack",
      "topicName": "Observability Stack",
      "environment": "[parameters('environmentName')]",
      "managed-by": "arsenal-deployer"
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('commonTags')]",
      "properties": {
        "sku": {"name": "PerGB2018"},
        "retentionInDays": "[parameters('retention_days')]",
        "features": {"enableLogAccessUsingOnlyResourcePermissions": true}
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "tags": "[variables('commonTags')]",
      "dependsOn": ["[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"],
      "properties": {
        "Application_Type": "web",
        "Flow_Type": "Bluefield",
        "Request_Source": "rest",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]",
        "IngestionMode": "LogAnalytics"
      }
    },
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[variables('containerGroupName')]",
      "location": "[parameters('location')]",
      "tags": "[variables('commonTags')]",
      "dependsOn": ["[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]"],
      "properties": {
        "osType": "Linux",
        "restartPolicy": "Always",
        "ipAddress": {
          "type": "Public",
          "dnsNameLabel": "[variables('dnsLabel')]",
          "ports": [
            {"protocol": "TCP", "port": 80}
          ]
        },
        "containers": [
          {
            "name": "demo-app",
            "properties": {
              "image": "mcr.microsoft.com/azuredocs/aci-helloworld:latest",
              "resources": {
                "requests": {"cpu": 1, "memoryInGB": 1.5}
              },
              "ports": [
                {"protocol": "TCP", "port": 80}
              ],
              "environmentVariables": [
                {
                  "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                  "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
                },
                {
                  "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
                  "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').InstrumentationKey]"
                },
                {"name": "ARSENAL_TOPIC", "value": "observability_stack"},
                {"name": "ARSENAL_DEMO", "value": "true"}
              ]
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Insights/actionGroups",
      "apiVersion": "2023-01-01",
      "name": "[variables('actionGroupName')]",
      "location": "global",
      "tags": "[variables('commonTags')]",
      "properties": {
        "groupShortName": "ArsenalOps",
        "enabled": true
      }
    },
    {
      "condition": "[parameters('enable_aiops')]",
      "type": "Microsoft.AlertsManagement/actionRules",
      "apiVersion": "2021-08-08",
      "name": "[variables('alertRuleName')]",
      "location": "global",
      "tags": "[variables('commonTags')]",
      "properties": {
        "scopes": ["[resourceGroup().id]"],
        "enabled": true,
        "description": "Suppress Sev3/Sev4 alerts as a sample alert processing rule.",
        "actions": [{"actionType": "RemoveAllActionGroups"}],
        "conditions": [{"field": "Severity", "operator": "Equals", "values": ["Sev3", "Sev4"]}]
      }
    }
  ],
  "outputs": {
    "webAppUrl": { "type": "string", "value": "[concat('http://', reference(resourceId('Microsoft.ContainerInstance/containerGroups', variables('containerGroupName'))).ipAddress.fqdn)]" },
    "containerGroupName": { "type": "string", "value": "[variables('containerGroupName')]" },
    "logAnalyticsWorkspaceName": { "type": "string", "value": "[variables('logAnalyticsName')]" },
    "appInsightsName": { "type": "string", "value": "[variables('appInsightsName')]" },
    "appInsightsConnectionString": { "type": "string", "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]" },
    "actionGroupId": { "type": "string", "value": "[resourceId('Microsoft.Insights/actionGroups', variables('actionGroupName'))]" }
  }
}
